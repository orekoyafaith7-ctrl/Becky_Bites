                    <div class="user-info">
                        <div class="user-img" style="background: url('https://i.pravatar.cc/150?u=2') center/cover;"></div>
                        <div>
                            <strong>Marcus T.</strong>
                            <p style="font-size: 0.8rem; color: #777;">Verified Customer</p>
                        </div>
                    </div>
                </div>
                <div class="testimonial-card reveal" style="transition-delay: 0.4s;">
