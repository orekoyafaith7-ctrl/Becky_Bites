                    </div>
                    <div class="process-step">
                        <div class="step-icon"><i data-lucide="package"></i></div>
                        <h3>Get It Delivered</h3>
                        <p>We'll bring the magic straight to your doorstep.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section>
        <div class="container">
            <h2 style="text-align: center; margin-bottom: 50px; font-family: var(--font-heading); font-size: 2.5rem;">What Our Fans Say</h2>
