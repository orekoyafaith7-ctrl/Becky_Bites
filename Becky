                    <a href="#menu" class="btn btn-primary">Order Now</a>
                    <div class="menu-toggle" id="menu-open">
                        <i data-lucide="menu"></i>
                    </div>
                </div>
            </nav>
        </div>
    </header>

    <div class="overlay" id="overlay"></div>
    <div class="mobile-nav" id="mobile-nav">
