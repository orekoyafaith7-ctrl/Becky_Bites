                    <div class="user-info">
                        <div class="user-img" style="background: url('https://i.pravatar.cc/150?u=3') center/cover;"></div>
                        <div>
                            <strong>Elena R.</strong>
                            <p style="font-size: 0.8rem; color: #777;">Verified Customer</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="container">
        <div class="promo-banner reveal">
            <h2>First Order?</h2>
            <p style="font-size: 1.2rem;">Get 15% Off Your First Box of Bites!</p>
            <div class="promo-code">CODE: BECKYFIRST</div>
            <p style="margin-top: 10px; font-size: 0.9rem; opacity: 0.8;">Limited time offer — Don't miss out!</p>
