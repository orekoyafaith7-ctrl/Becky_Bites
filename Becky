<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Becky_Bites | Every Bite Tells a Story</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,700&family=Plus+Jakarta+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>

    <style>
        :root {
            /* Color Palette */
            --primary-red: #D62828;
            --primary-red-hover: #B92121;
            --golden-yellow: #FCBF49;
            --cream-white: #FDFCF0;
            --deep-brown: #3D2B1F;
            --soft-brown: #6D594B;
            --accent-orange: #F77F00;
            --text-main: #2D241E;
            --white: #FFFFFF;
            
            /* Typography */
            --font-heading: 'Fraunces', serif;
            --font-body: 'Plus Jakarta Sans', sans-serif;
            
            /* Transitions & Shadows */
            --shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: var(--font-body);
            background-color: var(--cream-white);
            color: var(--text-main);
            line-height: 1.6;
            overflow-x: hidden;
        }

        /* --- Global Components --- */
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 14px 28px;
            border-radius: 50px;
            font-weight: 600;
            text-decoration: none;
            transition: var(--transition);
            cursor: pointer;
            border: none;
            gap: 8px;
        }

        .btn-primary {
            background-color: var(--primary-red);
            color: var(--white);
        }

        .btn-primary:hover {
            background-color: var(--primary-red-hover);
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(214, 40, 40, 0.3);
        }

        .btn-secondary {
            background-color: transparent;
            border: 2px solid var(--primary-red);
            color: var(--primary-red);
        }

        .btn-secondary:hover {
            background-color: var(--primary-red);
            color: var(--white);
        }

        section {
            padding: 100px 0;
        }

        .reveal {
            opacity: 0;
            transform: translateY(30px);
            transition: all 0.8s ease-out;
        }

        .reveal.active {
            opacity: 1;
            transform: translateY(0);
        }

        /* --- Header & Navigation --- */
        header {
            background-color: rgba(253, 252, 240, 0.95);
            backdrop-filter: blur(10px);
            position: sticky;
            top: 0;
            z-index: 1000;
            padding: 15px 0;
            box-shadow: var(--shadow);
        }

        nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            font-family: var(--font-heading);
            font-size: 1.8rem;
            color: var(--primary-red);
            text-decoration: none;
            font-weight: 700;
        }

        .nav-links {
            display: flex;
            list-style: none;
            gap: 30px;
        }

        .nav-links a {
            text-decoration: none;
            color: var(--deep-brown);
            font-weight: 500;
            transition: var(--transition);
        }

        .nav-links a:hover {
            color: var(--primary-red);
        }

        .header-actions {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .cart-icon {
            position: relative;
            cursor: pointer;
        }

        .cart-count {
            position: absolute;
            top: -8px;
            right: -8px;
            background: var(--accent-orange);
            color: white;
            font-size: 11px;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            font-weight: bold;
        }

        .menu-toggle {
            display: none;
            cursor: pointer;
        }

        /* --- Hero Section --- */
        .hero {
            padding: 60px 0 120px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .hero h1 {
            font-family: var(--font-heading);
            font-size: clamp(3rem, 8vw, 5rem);
            line-height: 1.1;
            margin-bottom: 20px;
            color: var(--deep-brown);
        }

        .hero p {
            font-size: 1.25rem;
            color: var(--soft-brown);
            max-width: 600px;
            margin: 0 auto 40px;
        }

        .hero-btns {
            display: flex;
            justify-content: center;
            gap: 15px;
            margin-bottom: 60px;
        }

        .floating-emoji {
            position: absolute;
            font-size: 2rem;
            animation: float 4s ease-in-out infinite;
            z-index: -1;
        }

        @keyframes float {
            0%, 100% { transform: translateY(0) rotate(0deg); }
            50% { transform: translateY(-20px) rotate(10deg); }
        }

        .trust-badges {
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
            gap: 40px;
            padding-top: 40px;
            border-top: 1px solid rgba(109, 89, 75, 0.1);
        }

        .badge-item {
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 600;
            color: var(--soft-brown);
            font-size: 0.9rem;
        }

        /* --- About Section --- */
        .about-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 80px;
            align-items: center;
        }

        .about-image {
            position: relative;
            justify-self: center;
        }

        .circular-frame {
            width: 400px;
            height: 400px;
            border-radius: 50%;
            background: var(--golden-yellow);
            overflow: hidden;
            border: 15px solid var(--white);
            box-shadow: var(--shadow);
        }

        .circular-frame img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .about-content h2 {
            font-family: var(--font-heading);
            font-size: 2.5rem;
            margin-bottom: 25px;
        }

        .value-list {
            list-style: none;
            margin-top: 30px;
        }

        .value-list li {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 15px;
            font-weight: 500;
        }

        .value-list i {
            color: var(--primary-red);
        }

        /* --- Menu Section --- */
        .menu-header {
            text-align: center;
            margin-bottom: 50px;
        }

        .filter-tabs {
            display: flex;
            justify-content: center;
            gap: 10px;
            margin-top: 30px;
            flex-wrap: wrap;
        }

        .tab {
            padding: 8px 24px;
            border-radius: 30px;
            background: var(--white);
            border: 1px solid #ddd;
            cursor: pointer;
            transition: var(--transition);
            font-weight: 500;
        }

        .tab.active, .tab:hover {
            background: var(--deep-brown);
            color: var(--white);
            border-color: var(--deep-brown);
        }

        .menu-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 30px;
        }

        .menu-card {
            background: var(--white);
            border-radius: 20px;
            overflow: hidden;
            box-shadow: var(--shadow);
            transition: var(--transition);
        }

        .menu-card:hover {
            transform: translateY(-10px);
        }

        .card-img {
            height: 220px;
            width: 100%;
            background: #eee;
            position: relative;
            overflow: hidden;
        }

        .card-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .card-content {
            padding: 25px;
        }

        .card-price {
            color: var(--primary-red);
            font-weight: 700;
            font-size: 1.2rem;
            margin-bottom: 10px;
        }

        .card-title {
            font-family: var(--font-heading);
            font-size: 1.4rem;
            margin-bottom: 10px;
        }

        .card-desc {
            color: var(--soft-brown);
            font-size: 0.95rem;
            margin-bottom: 20px;
        }

        /* --- How It Works --- */
        .process-bg {
            background-color: var(--golden-yellow);
            border-radius: 40px;
            padding: 60px;
        }

        .process-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 40px;
            text-align: center;
        }

        .step-icon {
            width: 80px;
            height: 80px;
            background: var(--white);
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            margin: 0 auto 20px;
            color: var(--primary-red);
            box-shadow: var(--shadow);
        }

        /* --- Testimonials --- */
        .testimonials-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
        }

        .testimonial-card {
            background: var(--white);
            padding: 40px;
            border-radius: 20px;
            border-bottom: 5px solid var(--golden-yellow);
        }

        .stars {
            color: var(--accent-orange);
            margin-bottom: 15px;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-top: 25px;
        }

        .user-img {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: #ccc;
        }

        /* --- Promo Banner --- */
        .promo-banner {
            background: var(--deep-brown);
            color: var(--white);
            border-radius: 30px;
            padding: 80px 40px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .promo-banner h2 {
            font-family: var(--font-heading);
            font-size: 3rem;
            margin-bottom: 15px;
        }

        .promo-code {
            display: inline-block;
            background: rgba(255,255,255,0.1);
            padding: 10px 20px;
            border: 2px dashed var(--golden-yellow);
            margin: 20px 0;
            font-weight: 700;
            letter-spacing: 2px;
        }

        .cta-form {
            display: flex;
            max-width: 500px;
            margin: 30px auto 0;
            gap: 10px;
        }

        .cta-form input {
            flex: 1;
            padding: 15px 25px;
            border-radius: 50px;
            border: none;
            outline: none;
        }

        /* --- Footer --- */
        footer {
            background: var(--white);
            padding: 80px 0 40px;
            border-top: 1px solid #eee;
        }

        .footer-grid {
            display: grid;
            grid-template-columns: 2fr 1fr 1fr 1.5fr;
            gap: 60px;
            margin-bottom: 60px;
        }

        .footer-logo-area p {
            margin-top: 20px;
            color: var(--soft-brown);
        }

        .footer-links h4 {
            margin-bottom: 25px;
            font-family: var(--font-heading);
        }

        .footer-links ul {
            list-style: none;
        }

        .footer-links li {
            margin-bottom: 12px;
        }

        .footer-links a {
            text-decoration: none;
            color: var(--soft-brown);
            transition: var(--transition);
        }

        .footer-links a:hover {
            color: var(--primary-red);
        }

        .social-icons {
            display: flex;
            gap: 15px;
            margin-top: 20px;
        }

        .social-icons a {
            width: 40px;
            height: 40px;
            background: #f4f4f4;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            color: var(--deep-brown);
            transition: var(--transition);
        }

        .social-icons a:hover {
            background: var(--primary-red);
            color: var(--white);
        }

        .copyright {
            text-align: center;
            padding-top: 40px;
            border-top: 1px solid #eee;
            color: #999;
            font-size: 0.9rem;
        }

        /* --- Mobile Responsiveness --- */
        @media (max-width: 992px) {
            .about-grid, .footer-grid {
                grid-template-columns: 1fr;
                gap: 40px;
            }
            .process-grid {
                grid-template-columns: 1fr;
            }
            .nav-links {
                display: none; /* In a real project, this would be the mobile menu */
            }
            .menu-toggle {
                display: block;
            }
            .hero h1 { font-size: 3.5rem; }
            .cta-form { flex-direction: column; }
        }

        /* Mobile Nav Overlay */
        .mobile-nav {
            position: fixed;
            top: 0;
            left: -100%;
            width: 80%;
            height: 100vh;
            background: var(--white);
            z-index: 2000;
            padding: 40px;
            transition: 0.4s ease;
            box-shadow: 10px 0 30px rgba(0,0,0,0.1);
        }

        .mobile-nav.active {
            left: 0;
        }

        .overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            z-index: 1500;
            display: none;
        }

        .overlay.active {
            display: block;
        }
    </style>
</head>
<body>

    <header>
        <div class="container">
            <nav>
                <a href="#" class="logo">Becky_Bites</a>
                <ul class="nav-links">
                    <li><a href="#home">Home</a></li>
                    <li><a href="#about">Our Story</a></li>
                    <li><a href="#menu">Menu</a></li>
                    <li><a href="#process">How it Works</a></li>
                </ul>
                <div class="header-actions">
                    <div class="cart-icon" onclick="updateCart(0)">
                        <i data-lucide="shopping-bag"></i>
                        <span class="cart-count" id="cart-count">0</span>
