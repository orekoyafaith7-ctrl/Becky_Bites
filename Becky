            <i data-lucide="x" id="menu-close" style="cursor: pointer;"></i>
        </div>
        <ul class="nav-links" style="display: flex; flex-direction: column; font-size: 1.5rem;">
            <li><a href="#home">Home</a></li>
            <li><a href="#about">Our Story</a></li>
            <li><a href="#menu">Menu</a></li>
            <li><a href="#process">How it Works</a></li>
        </ul>
    </div>

    <section class="hero" id="home">
        <span class="floating-emoji" style="top: 15%; left: 10%;">🍪</span>
        <span class="floating-emoji" style="top: 25%; right: 15%; animation-delay: 1s;">🧁</span>
        <span class="floating-emoji" style="bottom: 20%; left: 20%; animation-delay: 2s;">🍩</span>
        
        <div class="container">
            <h1 class="reveal">Every Bite<br><span style="color: var(--primary-red);">Tells a Story</span></h1>
            <p class="reveal">Handcrafted treats made with premium ingredients and a whole lot of heart. Delivered fresh to your doorstep.</p>
            <div class="hero-btns reveal">
                <a href="#menu" class="btn btn-primary">Order Now <i data-lucide="arrow-right"></i></a>
                <a href="#menu" class="btn btn-secondary">See Our Menu</a>
            </div>

            <div class="trust-badges reveal">
                <div class="badge-item"><i data-lucide="heart"></i> 100% Homemade</div>
                <div class="badge-item"><i data-lucide="zap"></i> Fresh Daily</div>
                <div class="badge-item"><i data-lucide="truck"></i> Free Delivery Over $30</div>
            </div>
        </div>
    </section>

    <section class="container" id="about">
        <div class="about-grid">
            <div class="about-image reveal">
                <div class="circular-frame">
                    <img src="https://images.unsplash.com/photo-1556910103-1c02745aae4d?auto=format&fit=crop&q=80&w=800" alt="Becky baking">
                </div>
                <div style="position: absolute; bottom: 20px; right: 20px; background: var(--white); padding: 15px; border-radius: 15px; box-shadow: var(--shadow);">
                    <p style="font-weight: bold; color: var(--primary-red);">"Baking is my love language!"</p>
                </div>
            </div>
            <div class="about-content reveal">
                <h2>Who is Becky?</h2>
                <p>Hi, I'm Becky! What started in my grandmother’s kitchen with a dusty rolling pin has grown into Becky_Bites. I believe that food should do more than just fill you up—it should make you smile.</p>
                <p style="margin-top: 15px;">Every recipe we use has been perfected over years of taste-testing (the best part of the job!) to ensure you get the perfect balance of flavor and nostalgia.</p>
                <ul class="value-list">
                    <li><i data-lucide="check-circle"></i> Sourced from Local Farmers</li>
                    <li><i data-lucide="check-circle"></i> Small Batch Production</li>
                    <li><i data-lucide="check-circle"></i> No Artificial Preservatives</li>
                </ul>
            </div>
        </div>
    </section>

    <section id="menu" style="background: #f9f8f0;">
        <div class="container">
            <div class="menu-header reveal">
                <h2>Our Delicious Menu</h2>
                <div class="filter-tabs">
                    <button class="tab active" onclick="filterMenu('all')">All</button>
                    <button class="tab" onclick="filterMenu('snacks')">Snacks</button>
                    <button class="tab" onclick="filterMenu('desserts')">Desserts</button>
                    <button class="tab" onclick="filterMenu('drinks')">Drinks</button>
                </div>
            </div>

            <div class="menu-grid" id="menu-container">
                </div>
        </div>
    </section>

    <section id="process">
        <div class="container">
            <div class="process-bg reveal">
                <h2 style="text-align: center; margin-bottom: 50px; font-family: var(--font-heading); font-size: 2.5rem;">As Easy As 1-2-3</h2>
                <div class="process-grid">
                    <div class="process-step">
                        <div class="step-icon"><i data-lucide="mouse-pointer-2"></i></div>
                        <h3>Browse Menu</h3>
                        <p>Choose from our rotating seasonal selection of treats.</p>
                    </div>
                    <div class="process-step">
                        <div class="step-icon"><i data-lucide="credit-card"></i></div>
