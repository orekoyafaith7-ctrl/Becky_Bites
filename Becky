            <div class="copyright">
                &copy; 2024 Becky_Bites Confectionery. All rights reserved.
            </div>
        </div>
    </footer>

    <script>
        // Initialize Icons
        lucide.createIcons();

        // Menu Data
        const menuItems = [
            { id: 1, name: "Midnight Brownies", category: "desserts", price: 12.99, desc: "Triple chocolate with a fudgy center.", img: "https://images.unsplash.com/photo-1461023058943-07fcbe16d735?auto=format&fit=crop&q=80&w=500" },
            { id: 2, name: "Golden Glazed Donuts", category: "desserts", price: 8.50, desc: "Hand-dipped in organic honey glaze.", img: "https://images.unsplash.com/photo-1527324688151-0e627063f2b1?auto=format&fit=crop&q=80&w=500" },
            { id: 3, name: "Spiced Chai Latte", category: "drinks", price: 5.50, desc: "House-blend spices with creamy milk.", img: "https://images.unsplash.com/photo-1576092768241-dec231879fc3?auto=format&fit=crop&q=80&w=500" },
            { id: 4, name: "Sea Salt Cookies", category: "snacks", price: 9.99, desc: "The perfect mix of sweet and salty.", img: "https://images.unsplash.com/photo-1499636136210-6f4ee915583e?auto=format&fit=crop&q=80&w=500" },
            { id: 5, name: "Berry Bliss Tart", category: "desserts", price: 14.00, desc: "Seasonal berries on a buttery crust.", img: "https://images.unsplash.com/photo-1519915028121-7d3463d20b13?auto=format&fit=crop&q=80&w=500" },
            { id: 6, name: "Cold Brew Vanilla", category: "drinks", price: 6.25, desc: "12-hour steep for ultimate smoothness.", img: "https://images.unsplash.com/photo-1517701604599-bb29b565090c?auto=format&fit=crop&q=80&w=500" }
        ];

        // Render Menu
        function renderMenu(items) {
            const container = document.getElementById('menu-container');
            container.innerHTML = items.map(item => `
                <div class="menu-card reveal active">
                    <div class="card-img">
                        <img src="${item.img}" alt="${item.name}">
                    </div>
                    <div class="card-content">
                        <div class="card-price">$${item.price}</div>
                        <h3 class="card-title">${item.name}</h3>
                        <p class="card-desc">${item.desc}</p>
                        <button class="btn btn-primary" style="width: 100%" onclick="addToCart()">Add to Cart</button>
                    </div>
                </div>
            `).join('');
        }

        function filterMenu(category) {
            // Update tabs
            document.querySelectorAll('.tab').forEach(tab => {
                tab.classList.toggle('active', tab.innerText.toLowerCase() === category);
            });

            if (category === 'all') {
                renderMenu(menuItems);
            } else {
                const filtered = menuItems.filter(item => item.category === category);
                renderMenu(filtered);
            }
        }

        // Cart Mockup
        let count = 0;
        function addToCart() {
            count++;
            document.getElementById('cart-count').innerText = count;
            // Simple animation
            const cart = document.querySelector('.cart-icon');
            cart.style.transform = 'scale(1.2)';
            setTimeout(() => cart.style.transform = 'scale(1)', 200);
        }

        // Reveal Animations on Scroll
        function reveal() {
            var reveals = document.querySelectorAll(".reveal");
            for (var i = 0; i < reveals.length; i++) {
                var windowHeight = window.innerHeight;
                var elementTop = reveals[i].getBoundingClientRect().top;
                var elementVisible = 150;
                if (elementTop < windowHeight - elementVisible) {
                    reveals[i].classList.add("active");
                }
            }
        }

        window.addEventListener("scroll", reveal);

        // Mobile Menu Logic
        const menuOpen = document.getElementById('menu-open');
        const menuClose = document.getElementById('menu-close');
        const mobileNav = document.getElementById('mobile-nav');
        const overlay = document.getElementById('overlay');

        menuOpen.onclick = () => {
            mobileNav.classList.add('active');
            overlay.classList.add('active');
        };

        const closeMenu = () => {
            mobileNav.classList.remove('active');
            overlay.classList.remove('active');
        };

        menuClose.onclick = closeMenu;
        overlay.onclick = closeMenu;

        // Initialize
        renderMenu(menuItems);
        reveal(); // Initial check
    </script>
</body>
</html>
